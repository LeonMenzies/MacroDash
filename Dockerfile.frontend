# Stage 1 — build
FROM node:18-alpine AS builder

WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ ./

# Bake the API base URL at build time (relative path so nginx can proxy it)
ARG REACT_APP_URL_BASE=/api
ENV REACT_APP_URL_BASE=$REACT_APP_URL_BASE

RUN npm run build

# Stage 2 — serve
FROM nginx:1.27-alpine

COPY --from=builder /app/build /usr/share/nginx/html
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
